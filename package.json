{
  "name": "glitchbomb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:all": "turbo run format:all",
    "format:check:all": "turbo run format:check:all",
    "format:cairo": "cd contracts && pnpm format",
    "format:check:cairo": "cd contracts && pnpm format:check:cairo",
    "lint:check:cairo": "cd contracts && pnpm lint:check:cairo",
    "format:ts": "cd client && pnpm biome check --write .",
    "format:check:ts": "cd client && pnpm biome check .",
    "lint:check:ts": "cd client && pnpm lint",
    "test": "turbo run test",
    "test:ts": "cd client && pnpm test",
    "storybook": "cd client && pnpm storybook",
    "storybook:build": "cd client && pnpm storybook:build",
    "storybook:serve": "cd client && pnpm storybook:build --quiet && pnpm http-server -c-1 storybook-static --port 6001 --silent",
    "build-storybook": "cd client && pnpm storybook:build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "husky": "^9.1.7",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@11.0.5+sha512.94fa09e72016402aefce788e46994e18eb1922998b16b6fd5aa6bafd8ae4dea05d0852f60247fdb7d5ab8199a7b0beda830398f3f80cb9f822398522a1535481"
}
